.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Flask local runtime files
instance/
.webassets-cache/

# Local live data (the baseline schema and backups remain versioned)
database/pokemon.db

# JavaScript dependencies and logs
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local editor and operating-system files
.DS_Store
Thumbs.db
.vscode/
.idea/

backups/*.db
