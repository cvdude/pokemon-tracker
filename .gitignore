# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Python environments and package build output
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
.eggs/

# Test, coverage, and type-checking output
.coverage
.coverage.*
htmlcov/
